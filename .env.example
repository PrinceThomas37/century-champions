# ---- Database (Supabase Postgres) ----
# Get these from your Supabase project:
#   Dashboard -> Project Settings -> Database -> Connection string
#
# DATABASE_URL = the POOLED connection (Supavisor, port 6543) used by the app at runtime.
#   Append ?pgbouncer=true&connection_limit=1 for serverless (Vercel).
# DIRECT_URL   = the DIRECT connection (port 5432) used only for migrations.
#
# Replace [PASSWORD] with your database password (Settings -> Database -> Reset database password).
DATABASE_URL="postgresql://postgres.ryvxgpyxevjzkjfteghg:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.ryvxgpyxevjzkjfteghg:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ---- Auth ----
# Secret used to sign session cookies. Use a long random string in production.
SESSION_SECRET="change-me-to-a-long-random-string"

# Dev OTP mode: when "true", no SMS is sent — any phone logs in with DEV_OTP_CODE,
# and the code is shown on screen. Set to "false" once a real SMS gateway is wired.
DEV_OTP_MODE="true"
DEV_OTP_CODE="123456"

# ---- Admin ----
# Shared password gate for the /admin dashboard (MVP). Replace with staff accounts later.
ADMIN_PASSWORD="century-admin"
