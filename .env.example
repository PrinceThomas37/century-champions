# ---- Database ----
# Local dev default: SQLite file (zero setup).
# To use Supabase/Postgres later, switch prisma/schema.prisma datasource provider
# to "postgresql" and set this to your Supabase connection string.
DATABASE_URL="file:./dev.db"

# ---- Auth ----
# Secret used to sign session cookies. Change this in any real deployment.
SESSION_SECRET="dev-secret-change-me"

# Dev OTP mode: when "true", the OTP is not sent over SMS. Instead any phone can log
# in using the fixed dev code below (and the code is returned in the API response so
# you can test without an SMS provider). Set to "false" once a real SMS gateway is wired.
DEV_OTP_MODE="true"
DEV_OTP_CODE="123456"

# ---- Admin ----
# Simple shared password gate for the /admin dashboard (MVP).
# Replace with proper staff accounts before production.
ADMIN_PASSWORD="century-admin"
